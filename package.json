{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "vue-template",
    "version": "0.1.0",
    "private": false,
    "description": "A template with Nuxt3 built on Vue3 with focus on performance and best practices.",
    "keywords": [
        "template"
    ],
    "homepage": "https://github.com/krudi/vue-template#readme",
    "bugs": {
        "url": "https://github.com/krudi/vue-template/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/krudi/vue-template.git"
    },
    "license": "MIT",
    "author": {
        "name": "krudi",
        "email": "patryk.kudlik@gmail.com",
        "url": "https://krudi.io"
    },
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "clean": "rm -rf .cache node_modules .nuxt .output",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "lint:eslint": "eslint --flag unstable_native_nodejs_ts_config . --cache --cache-location .cache/.eslintcache",
        "lint:eslint:fix": "eslint --flag unstable_native_nodejs_ts_config . --fix --cache --cache-location .cache/.eslintcache",
        "lint:prettier": "prettier --check . --cache --cache-strategy metadata --cache-location .cache/.prettiercache",
        "lint:prettier:fix": "prettier --write . --cache --cache-strategy metadata --cache-location .cache/.prettiercache",
        "lint:stylelint": "stylelint --cache --cache-location .cache/.stylelintcache -c ./stylelint.config.ts **/*.css",
        "lint:stylelint:fix": "stylelint --cache --cache-location .cache/.stylelintcache -c ./stylelint.config.ts --fix **/*.css",
        "preview": "nuxt preview",
        "start": "node .output/server/index.mjs",
        "typecheck": "nuxt typecheck"
    },
    "devDependencies": {
        "@krudi/prettier-config": "^0.1.8",
        "@krudi/stylelint-config": "^0.1.1",
        "@krudi/typescript-config": "^0.1.9",
        "@nuxt/devtools": "^3.2.4",
        "@nuxt/eslint": "^1.15.2",
        "@types/node": "^25.5.2",
        "autoprefixer": "^10.4.27",
        "eslint": "^10.2.0",
        "nuxt": "^4.4.2",
        "postcss": "^8.5.9",
        "postcss-import": "^16.1.1",
        "postcss-load-config": "^6.0.1",
        "postcss-nesting": "^14.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "vue-tsc": "^3.2.6"
    },
    "packageManager": "npm@11.12.1",
    "engines": {
        "node": ">= 24.14.0",
        "npm": ">= 11.6.4"
    }
}
